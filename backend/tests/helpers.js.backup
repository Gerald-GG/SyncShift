// tests/helpers.js
process.env.DOTENV_CONFIG_PATH = '.env.test';
require('dotenv').config({ path: '.env.test', override: true });

const request = require('supertest');  // ✅ ADD THIS - missing import
const db = require('../src/config/db');
const app = require('../src/app');

/**
 * Run latest migrations
 */
const migrate = async () => {
  await db.migrate.latest();
};

/**
 * Rollback all migrations (clean slate)
 */
const rollback = async () => {
  await db.migrate.rollback(null, true);
};

/**
 * Truncate specific tables safely (FK-aware)
 */
const truncate = async (...tables) => {
  if (!tables.length) return;

  const tableList = tables.join(', ');

  await db.raw(`
    TRUNCATE ${tableList}
    RESTART IDENTITY CASCADE;
  `);
};

/**
 * Truncate ALL tables in public schema (recommended)
 */
const truncateAll = async () => {
  const result = await db.raw(`
    SELECT tablename 
    FROM pg_tables 
    WHERE schemaname = 'public';
  `);

  const tables = result.rows
    .map(row => `"${row.tablename}"`)
    .filter(name => name !== '"knex_migrations"' && name !== '"knex_migrations_lock"');

  if (tables.length === 0) return;

  await db.raw(`
    TRUNCATE ${tables.join(', ')}
    RESTART IDENTITY CASCADE;
  `);
};

/**
 * Close DB connection (important for Jest exit)
 */
const closeDb = async () => {
  await db.destroy();
};

/**
 * Create an admin token for testing
 */
async function createAdminToken() {
  const adminEmail = `admin_${Date.now()}@syncshift.dev`;
  
  // Register admin
  await request(app)
    .post('/api/auth/register')
    .send({
      name: 'Test Admin',
      email: adminEmail,
      password: 'Admin123!',
      phone: '0712345678',
      role: 'admin'
    });
  
  // Login
  const loginRes = await request(app)
    .post('/api/auth/login')
    .send({
      email: adminEmail,
      password: 'Admin123!'
    });
  
  return loginRes.body.data.accessToken;
}

/**
 * Create an employee token for testing
 */
async function createEmployeeToken() {
  const employeeEmail = `employee_${Date.now()}@syncshift.dev`;
  
  await request(app)
    .post('/api/auth/register')
    .send({
      name: 'Test Employee',
      email: employeeEmail,
      password: 'Employee123!',
      phone: '0712345678'
    });
  
  const loginRes = await request(app)
    .post('/api/auth/login')
    .send({
      email: employeeEmail,
      password: 'Employee123!'
    });
  
  return loginRes.body.data.accessToken;
}

// ✅ SINGLE module.exports with all functions
module.exports = { 
  app, 
  db, 
  migrate, 
  rollback, 
  truncate, 
  truncateAll, 
  closeDb,
  createAdminToken,
  createEmployeeToken
};