{
  "name": "syncshift-backend",
  "version": "1.0.0",
  "description": "SyncShift REST API — geolocation-aware attendance tracking",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "export $(grep -v '^#' .env.test | xargs) && NODE_ENV=test jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run"
  },
