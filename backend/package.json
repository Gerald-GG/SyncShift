    "csv-stringify": "^6.7.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "pg": "^8.20.0",
    "uuid": "^8.3.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
